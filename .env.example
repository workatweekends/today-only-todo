# AdMob 本番設定
# 1. このファイルを .env にコピー:  cp .env.example .env
# 2. AdMob 管理画面 (https://admob.google.com/) で取得した ID を入れる
# 3. 本番ビルド前に EAS Secrets にも同じ値を登録する

# --- 開発中は true のまま（Google テスト広告を表示）---
EXPO_PUBLIC_USE_TEST_ADS=true

# --- AdMob アプリ ID（アプリ登録時に発行 / ca-app-pub-xxx~xxx 形式）---
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx

# --- バナー広告ユニット ID（広告ユニット作成時に発行 / ca-app-pub-xxx/xxx 形式）---
EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy

# --- プライバシーポリシー ---
EXPO_PUBLIC_OPERATOR_NAME=今日だけToDo 運営
EXPO_PUBLIC_CONTACT_EMAIL=your-email@example.com
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-name.github.io/today-only-todo/privacy-policy.html
